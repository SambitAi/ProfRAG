# LLM provider routing: google_native | google | azure | openai
LLM_PROVIDER=google
# Optional override for summaries only (google_native | google | azure | openai)
SUMMARIZER_LLM_PROVIDER=

# OpenAI (use this OR Azure OR Google below, not multiple)
OPENAI_API_KEY=

# Azure OpenAI (use this OR OpenAI OR Google)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Google Gemini
# Option A: API key (Gemini Developer API)
GOOGLE_API_KEY=
# Option B: ADC (gcloud auth application-default login)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_OPENAI_ENDPOINT_ID=openapi

# Docker only (leave blank for local dev)
CHROMA_HOST=
CHROMA_PORT=8000
